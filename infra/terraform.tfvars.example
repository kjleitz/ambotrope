aws_region            = "us-east-1"
project_name          = "ambotrope"
environment           = "production"
domain_name           = "ambotrope.com"
domain_enabled        = false
availability_zone     = "us-east-1a"
instance_bundle_id    = "nano_3_0"
instance_blueprint_id = "ubuntu_24_04"
ssh_public_key_path   = "~/.ssh/id_ed25519.pub"
server_image          = "ghcr.io/kjleitz/ambotrope-server:latest"
cors_origin           = "https://www.ambotrope.com"

# Tighten this before production if you have a stable office/VPN IP.
ssh_allowed_cidrs = ["0.0.0.0/0"]
